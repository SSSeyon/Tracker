# Service worker — never cache, always fresh
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Manifest — short cache
/manifest.json
  Cache-Control: public, max-age=86400

# HTML — revalidate on each visit
/index.html
  Cache-Control: no-cache

# App code & styles — referenced by a static path, so revalidate to avoid
# serving stale JS/CSS after a deploy
/app.js
  Cache-Control: no-cache
/styles.css
  Cache-Control: no-cache

# Everything else — cache for a week
/*
  Cache-Control: public, max-age=604800
